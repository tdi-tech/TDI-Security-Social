# Seguridad HTTP - Innova Management

<IfModule mod_headers.c>

  # 1. Prevenir Clickjacking
  Header always set X-Frame-Options "DENY"

  # 2. Prevenir MIME Sniffing
  Header always set X-Content-Type-Options "nosniff"

  # 3. Forzar HTTPS estricto
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # 4. Política de Referrer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # 5. Bloquear permisos de hardware no usados
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # 6. Content Security Policy compatible con React/Vite y Firebase
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*.firebaseio.com wss://*.firebaseio.com https://*.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none';"

</IfModule>