# Seguridad HTTP - Innova Management

<IfModule mod_headers.c>

  # 1. Prevenir Clickjacking
  Header always set X-Frame-Options "DENY"

  # 2. Prevenir MIME Sniffing
  Header always set X-Content-Type-Options "nosniff"

  # 3. Forzar HTTPS estricto
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # 4. Política de Referrer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # 5. Bloquear permisos de hardware no usados
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)"

  # 6. Necesario para Google Login (popup)
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  # 7. Content Security Policy
  Header always set Content-Security-Policy "
    default-src 'self';
    script-src 'self'
      https://apis.google.com
      https://www.gstatic.com
      https://www.googleapis.com;
    style-src 'self' 'unsafe-inline';
    img-src 'self' data: blob: https:;
    font-src 'self' data: https:;
    connect-src 'self'
      https://ipinfo.io
      https://*.firebaseio.com
      wss://*.firebaseio.com
      https://*.googleapis.com
      https://firestore.googleapis.com
      https://identitytoolkit.googleapis.com
      https://securetoken.googleapis.com;
    frame-src 'self'
      https://auth-innova.handcraftprueba.com
      https://accounts.google.com
      https://apis.google.com;
    frame-ancestors 'none';
    object-src 'none';
    base-uri 'self';
    form-action 'self';
    upgrade-insecure-requests;
  "

</IfModule>