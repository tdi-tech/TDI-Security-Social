rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAnySignedIn() {
      return request.auth != null;
    }

    function userPath(appId) {
      return /databases/$(database)/documents/artifacts/$(appId)/public/data/users/$(request.auth.token.email);
    }

    function userExists(appId) {
      return isAuthenticated() && exists(userPath(appId));
    }

    function getUserData(appId) {
      return get(userPath(appId)).data;
    }

    function hasRole(appId, role) {
      return userExists(appId) && getUserData(appId).role == role;
    }

    function isITAdmin(appId) {
      return hasRole(appId, 'ADMIN_IT');
    }

    function isCMAdmin(appId) {
      return hasRole(appId, 'ADMIN_CM');
    }

    function isCMEditor(appId) {
      return hasRole(appId, 'EDITOR_CM');
    }

    function isCMTeam(appId) {
      return isITAdmin(appId) || isCMAdmin(appId) || isCMEditor(appId);
    }

    match /artifacts/{appId}/public/data {

      match /users/{userEmail} {
        allow read: if isITAdmin(appId)
          || isCMAdmin(appId)
          || (
            isAuthenticated()
            && request.auth.token.email == userEmail
          );

        allow create: if (
          isAuthenticated()
          && request.auth.token.email == userEmail
          && request.resource.data.role == 'READER'
          && request.resource.data.disabled == false
          && request.resource.data.isProtected == false
        )
        || isITAdmin(appId)
        || (
          isCMAdmin(appId)
          && request.resource.data.role != 'ADMIN_IT'
          && request.resource.data.isProtected != true
        );

        allow update: if (
          isAuthenticated()
          && request.auth.token.email == userEmail
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'disabled', 'isProtected'])
        )
        || (
          isITAdmin(appId)
          && resource.data.get('isProtected', false) != true
        )
        || (
          isCMAdmin(appId)
          && resource.data.get('isProtected', false) != true
          && resource.data.role != 'ADMIN_IT'
          && request.resource.data.role != 'ADMIN_IT'
          && request.resource.data.isProtected != true
        );

        allow delete: if isITAdmin(appId)
          && resource.data.get('isProtected', false) != true;
      }

      match /incidents/{incidentId} {
        allow read: if isAnySignedIn();
        allow create, update, delete: if isITAdmin(appId);
      }

      match /rrss_incidents/{incidentId} {
        allow read: if isAnySignedIn();
        allow create, update, delete: if isCMTeam(appId);
      }

      match /comments/{commentId} {
        allow read: if isAnySignedIn();
        allow create: if isCMTeam(appId);
        allow update, delete: if isITAdmin(appId) || isCMAdmin(appId);
      }

      match /notifications/{notificationId} {
        allow read: if isAnySignedIn();
        allow create, update: if userExists(appId);
        allow delete: if isITAdmin(appId);
      }

      match /auditLogs/{logId} {
        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly([
            'ip',
            'pais',
            'fecha',
            'uid',
            'email',
            'provider',
            'userAgent',
            'accion',
            'expireAt'
          ])
          && request.resource.data.ip is string
          && request.resource.data.pais is string
          && request.resource.data.fecha is timestamp
          && request.resource.data.expireAt is timestamp
          && request.resource.data.uid is string
          && request.resource.data.provider is string
          && request.resource.data.accion is string
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.expireAt > request.time
          && request.resource.data.expireAt <= request.time + duration.value(14, 'd');

        allow read: if isITAdmin(appId);

        // Inalterable, con purga controlada por ADMIN_IT.
        allow delete: if isITAdmin(appId);
        allow update: if false;
      }

      match /appState/{docId} {
        allow read: if isAnySignedIn();
        allow write: if isITAdmin(appId);
      }
    }
  }
}